# ===========================================
# HEAR ME - Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# NE JAMAIS commiter .env.local !
# ===========================================

# --- SUPABASE ---
# Récupère ces valeurs sur https://supabase.com/dashboard > ton projet > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- STRIPE ---
# Récupère la clé publique sur https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- GOOGLE VISION API (modération photos) ---
# Créer une clé sur https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=AIza...

# --- PERSPECTIVE API (modération texte) ---
# Demander l'accès sur https://perspectiveapi.com/
PERSPECTIVE_API_KEY=AIza...

# --- iTunes Search API ---
# Aucune clé nécessaire - API publique d'Apple !
# ITUNES_API_BASE_URL=https://itunes.apple.com (déjà dans le code)

# --- ENVIRONNEMENT ---
APP_ENV=development
