{
  "expo": {
    "name": "Hear Me",
    "slug": "hear-me",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hearme",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hearme.app",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Hear Me a besoin de la caméra pour prendre des photos de profil.",
        "NSPhotoLibraryUsageDescription": "Hear Me a besoin d'accéder à ta galerie pour importer des photos de profil.",
        "NSLocationWhenInUseUsageDescription": "Hear Me utilise ta position pour détecter ta ville et trouver des profils près de toi.",
        "NSMicrophoneUsageDescription": "Hear Me a besoin du microphone pour la vérification de compte en vidéo.",
        "NSFaceIDUsageDescription": "Hear Me utilise Face ID pour sécuriser ta connexion.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hearme.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B9D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.hearme.app",
          "enableGooglePay": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Hear Me a besoin de la caméra pour ta vérification de compte."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Hear Me accède à ta galerie pour tes photos de profil.",
          "cameraPermission": "Hear Me utilise la caméra pour prendre ta photo de profil."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Hear Me utilise ta position pour détecter ta ville."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B9D"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF6B9D",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "62446bb0-25d1-4dc7-8d25-62090e10aad0"
      }
    },
    "owner": "fournierquentin",
    "runtimeVersion": "exposdk:56.0.0",
    "updates": {
      "url": "https://u.expo.dev/62446bb0-25d1-4dc7-8d25-62090e10aad0"
    }
  }
}
